OPENAI_API_KEY=your_openai_api_key_here

# Optional board persistence mode:
# - file: persists to .data/board.json (best for local development)
# - memory: deploy-safe, but board state resets with serverless cold starts / restarts
# Default behavior:
# - local development -> file
# - production / Vercel -> memory
# BOARD_STORAGE_MODE=memory
